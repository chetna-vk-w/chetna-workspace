# Keep-alive timeout in milliseconds (default: 24 hours)
KEEP_ALIVE_TIMEOUT=86400000

# Auto-shutdown after inactivity (in milliseconds, 0 = disabled)
AUTO_SHUTDOWN_TIMEOUT=0

# Database path
DB_PATH=./ssh_connections.db

# SFTP base path for local file storage
SFTP_BASE_PATH=./sftp-data

# Max concurrent SSH sessions (default: 10)
MAX_CONCURRENT_SESSIONS=10

# Tool defer loading (true = only show ssh_tool_search, false = show all tools)
ENABLE_DEFER_LOADING=false

# Session inactivity timeout in ms (default: 2 hours)
SESSION_TIMEOUT=7200000

# Default command timeout in ms (default: 5 minutes)
COMMAND_TIMEOUT=300000

# Max output size per command in bytes (default: 1MB)
MAX_OUTPUT_SIZE=1048576

# WebSocket streaming server (for real-time shell output)
WS_PORT=8765
WS_ENABLED=true
