# Search Wrapper Configuration
# Copy this file to .env and update values

# SearXNG - Self-hosted search instance (DEFAULT)
# Run your own: docker run -d -p 8080:8080 searxng/searxng
SEARXNG_URL=http://localhost:8080

# DuckDuckGo (fallback - has rate limits)
DDG_ENABLED=true

# Delay between requests in milliseconds (helps avoid rate limiting)
# For high usage: 2000-5000ms recommended
DELAY_MS=2000
